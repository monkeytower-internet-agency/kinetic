---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const allSections = await getCollection("sections");
const hero = allSections.find(s => s.id.endsWith('hero'))?.data;
const intro = allSections.find(s => s.id.endsWith('intro'))?.data;
const cls = allSections.find(s => s.id.endsWith('cls'))?.data;
const agility = allSections.find(s => s.id.endsWith('agility-control'))?.data;
const story = allSections.find(s => s.id.endsWith('story-tired'))?.data;
const fit = allSections.find(s => s.id.endsWith('fit-system'))?.data;
const faq = allSections.find(s => s.id.endsWith('faq'))?.data;

// Brand Title
const pageTitle = "KINETIC | pure control - das neue Gurtzeug von Profly";
---

<MainLayout title={pageTitle}>
  {/* HERO SECTION */}
  <section id="hero" class="min-h-[90vh] flex flex-col items-center justify-center text-center px-4 pt-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative z-10 space-y-8 max-w-5xl mx-auto">
      <h1 class="text-7xl md:text-9xl font-black tracking-tighter text-content animate-in fade-in slide-in-from-bottom-10 duration-1000">
        {hero?.heading || "KINETIC"}
      </h1>
      <p class="text-xl md:text-3xl font-medium tracking-widest text-brand uppercase animate-in fade-in slide-in-from-bottom-5 duration-1000 delay-200">
        - pure control -
      </p>
      <p class="text-lg md:text-xl text-content/60 max-w-2xl mx-auto font-light leading-relaxed animate-in fade-in duration-1000 delay-500">
        das neue Gurtzeug von Profly.
      </p>
      <div class="pt-10 flex flex-col md:flex-row gap-4 justify-center animate-in fade-in duration-1000 delay-700">
        <a href="#kontakt" class="btn-primary min-w-[280px]">
          {hero?.button_text || "Beratung anfragen / Early Access"}
        </a>
      </div>
    </div>
  </section>

  {/* INTRO: Warum es im Sitz beginnt */}
  <section id="features" class="py-24 md:py-40 bg-surface/30">
    <div class="max-w-7xl mx-auto px-6 md:px-8 grid md:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <span class="inline-block px-4 py-1.5 rounded-full bg-brand/10 text-brand text-xs font-bold tracking-widest uppercase">
          Das Sitzprinzip
        </span>
        <h2 class="text-4xl md:text-6xl font-bold tracking-tight text-content leading-tight">
          {intro?.heading || "Warum es im Sitz beginnt"}
        </h2>
        <div class="prose prose-invert prose-lg text-content/70 leading-relaxed font-light">
          {intro?.content || "Viele glauben, Kontrolle entsteht über die Hände..."}
        </div>
      </div>
      <div class="aspect-square bg-zinc-800 rounded-3xl overflow-hidden shadow-2xl border border-white/5 relative group">
         <div class="absolute inset-0 bg-gradient-to-br from-brand/20 to-transparent"></div>
         <div class="absolute inset-0 flex items-center justify-center font-bold text-white/20 italic">
            [Product Image Kinetic]
         </div>
      </div>
    </div>
  </section>

  {/* STORY SECTION */}
  <section class="py-24 bg-brand/5 border-y border-brand/10">
    <div class="max-w-4xl mx-auto px-6 text-center space-y-12">
      <span class="text-xs font-bold tracking-[0.3em] uppercase text-content/40">Kundenstory</span>
      <blockquote class="text-3xl md:text-5xl font-light italic text-content leading-snug">
        "{story?.heading || "Endlich keine Müdigkeit mehr im Körper."}"
      </blockquote>
      <p class="text-lg md:text-xl text-content/60 leading-relaxed max-w-2xl mx-auto font-light">
        {story?.content}
      </p>
      <p class="text-xl font-bold text-brand italic">
        {story?.subheading}
      </p>
    </div>
  </section>

  {/* TECH: CLS & CORE LOCK */}
  <section id="specs" class="py-24 md:py-40">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-20 space-y-6">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tight">
          {cls?.heading || "CORE LOCK SYSTEM (TM)"}
        </h2>
        <p class="text-xl text-content/60 font-light">
          {cls?.content}
        </p>
        <p class="text-2xl font-bold text-brand tracking-widest uppercase py-4">
          {cls?.subheading}
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
         {[
           { title: "LONG-FLIGHT SUPPORT", desc: "Sitzbrett mit voller Oberschenkelstütze. Weil Sitzkomfort Leistung ist." },
           { title: "BALANCE-LOCK", desc: "Pilotengewicht im Schwerpunkt — kein Rutschen, klare Rückmeldung." },
           { title: "CLS", desc: "Körpergerechte Passform und Lastpfade als Einheit im Schwerpunkt." }
         ].map(feature => (
           <div class="p-10 rounded-3xl bg-surface/50 border border-white/5 space-y-6 hover:border-brand/40 transition-all duration-300">
              <h3 class="text-xl font-bold text-brand">{feature.title}</h3>
              <p class="text-content/60 font-light leading-relaxed">{feature.desc}</p>
           </div>
         ))}
      </div>
    </div>
  </section>

  {/* AGILITY CONTROL */}
  <section class="py-24 bg-zinc-900 overflow-hidden relative">
     <div class="max-w-7xl mx-auto px-6 md:px-8 grid md:grid-cols-2 gap-20 items-center">
        <div class="relative z-10 space-y-8">
           <h2 class="text-4xl md:text-6xl font-bold tracking-tight">
             {agility?.heading || "AGILITY CONTROL™"}
           </h2>
           <p class="text-xl text-content/70 font-light leading-relaxed">
             {agility?.content}
           </p>
           <div class="p-6 bg-brand/10 border-l-4 border-brand rounded-r-2xl italic text-content/90 font-medium">
             "{agility?.subheading}"
           </div>
        </div>
        <div class="aspect-video bg-zinc-800 rounded-3xl shadow-2xl flex items-center justify-center font-bold text-white/5 relative">
            [Feature Illustration Agility Control]
            <div class="absolute bottom-6 left-6 right-6 flex justify-between text-[10px] tracking-widest font-bold uppercase text-white/40">
               <span>Dämpfung Max</span>
               <span>Feedback Max</span>
            </div>
        </div>
     </div>
  </section>

  {/* FIT SYSTEM */}
  <section id="sizing" class="py-24 md:py-40 bg-surface/30">
    <div class="max-w-4xl mx-auto px-6 text-center space-y-8">
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight">{fit?.heading}</h2>
      <p class="text-xl text-content/60 font-light">{fit?.content}</p>
      
      <div class="grid grid-cols-3 gap-4 pt-10">
         {fit?.items?.map(item => (
            <div class="p-8 bg-surface rounded-2xl border border-white/5 space-y-2">
               <span class="text-4xl font-black text-brand">{item.value}</span>
               <span class="block text-xs uppercase tracking-widest text-content/40 font-bold">{item.label}</span>
            </div>
         ))}
      </div>
      <div class="pt-10">
         <a href="#kontakt" class="btn-outline">
            {fit?.button_text}
         </a>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section id="faq" class="py-24 md:py-40 border-t border-white/5">
    <div class="max-w-4xl mx-auto px-6 space-y-16">
      <h2 class="text-4xl font-bold text-center">{faq?.heading}</h2>
      <div class="space-y-4">
        {faq?.items?.map(item => (
          <div class="p-8 rounded-2xl bg-surface/50 border border-white/5 hover:border-brand/20 transition-all active:scale-[0.99] cursor-pointer group">
            <h3 class="text-xl font-bold group-hover:text-brand transition-colors mb-4">{item.label}</h3>
            <p class="text-content/60 font-light leading-relaxed">{item.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CONTACT */}
  <section id="kontakt" class="py-24 md:py-40 bg-brand text-white">
     <div class="max-w-5xl mx-auto px-6 text-center space-y-10">
        <h2 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic">Stay in Control.</h2>
        <p class="text-xl md:text-2xl font-light opacity-80 max-w-2xl mx-auto">
          Interessiert am KINETIC? Hinterlasse uns deine Nachricht für Updates zum Launch oder eine persönliche Beratung.
        </p>
        <div class="pt-10">
           <a href="mailto:info@profly.org" class="inline-flex px-12 py-6 bg-white text-brand font-black text-xl rounded-full shadow-2xl hover:scale-105 active:scale-95 transition-all uppercase tracking-widest">
              Nimm Kontakt auf
           </a>
        </div>
     </div>
  </section>
</MainLayout>

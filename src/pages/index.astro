---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import Hero3D from "../components/Hero3D";
import FAQAccordion from "../components/FAQAccordion";



const allSections = await getCollection("sections");
const hero = allSections.find(s => s.id.endsWith('/hero') || s.data.slug === 'hero')?.data;
const intro = allSections.find(s => s.id.endsWith('/intro') || s.data.slug === 'intro')?.data;
const storyTired = allSections.find(s => s.id.endsWith('/story-tired') || s.data.slug === 'story-tired')?.data;
const cls = allSections.find(s => s.id.endsWith('/cls') || s.data.slug === 'cls')?.data;
const agility = allSections.find(s => s.id.endsWith('/agility-control') || s.data.slug === 'agility-control')?.data;
const safety = allSections.find(s => s.id.endsWith('/safety') || s.data.slug === 'safety')?.data;
const storyCalm = allSections.find(s => s.id.endsWith('/story-calm') || s.data.slug === 'story-calm')?.data;
const media = allSections.find(s => s.id.endsWith('/media') || s.data.slug === 'media')?.data;
const specs = allSections.find(s => s.id.endsWith('/specs') || s.data.slug === 'specs')?.data;
const fit = allSections.find(s => s.id.endsWith('/fit-system') || s.data.slug === 'fit-system')?.data;

const faq = allSections.find(s => s.id.endsWith('/faq') || s.data.slug === 'faq')?.data;



// Brand Title
const pageTitle = "KINETIC | pure control - das neue Gurtzeug von Profly";

---

<MainLayout title={pageTitle}>
  {/* HERO SECTION */}
  <section id="hero" class="modular-section relative overflow-hidden bg-body transition-colors duration-700">

      <div class="absolute inset-0 bg-gradient-to-b from-brand/20 via-body to-body opacity-80 pointer-events-none transition-colors duration-700"></div>



    {/* Layer 1: Immersion Layer - Full width and height (No Boxes!) */}
    <div class="absolute inset-0 z-10 pointer-events-auto overflow-hidden">
      <Hero3D client:only="react" />
    </div>

    {/* Layer 2: Mobile Scroll Side-Grip (Invisible touch-path for scrolling on mobile - above 3D, below text) */}
    <div class="md:hidden absolute left-0 top-0 bottom-0 w-[15%] z-20 pointer-events-auto touch-pan-y"></div>
    <div class="md:hidden absolute right-0 top-0 bottom-0 w-[15%] z-20 pointer-events-auto touch-pan-y"></div>

    {/* Layer 3: Text & UI (Floating ABOVE the model) */}
    <div id="hero-hud" class="relative z-30 space-y-4 max-w-7xl mx-auto py-10 transition-all duration-700">
      <div class="space-y-4">
        <p class="text-3xl md:text-5xl lg:text-7xl font-black tracking-[0.4em] text-brand uppercase animate-in fade-in slide-in-from-bottom-5 duration-1000 delay-300 drop-shadow-2xl">
          {hero?.subheading?.split('\n')[0] || "- pure control -"}
        </p>

        <p class="text-lg md:text-2xl text-content/40 max-w-2xl mx-auto font-light leading-relaxed animate-in fade-in duration-1000 delay-700">
          {hero?.subheading?.split('\n')[1] || "KINETIC - das neue Paragliding-Gurtzeug von ProFly"}
        </p>



      </div>

      <div class="pt-8 flex flex-col md:flex-row gap-4 justify-center animate-in fade-in duration-1000 delay-1000 relative z-50">
        <a href="/kontakt" class="btn-primary min-w-[280px]">
          {hero?.button_text || "Beratung anfragen / Early Access"}
        </a>
      </div>
    </div>


    {/* Scroll Indicator - Mobile ONLY hint, acts as a scroll-safe bridge */}
    <div class="md:hidden absolute bottom-12 left-1/2 -translate-x-1/2 z-40 opacity-80 animate-pulse pointer-events-auto touch-pan-y flex flex-col items-center gap-4 cursor-row-resize w-[85vw]">
       <span class="text-[9px] tracking-[0.2em] uppercase font-black text-white select-none text-center">Swipe to Rotate / Scroll to continue</span>
       <div class="w-px h-8 bg-gradient-to-b from-white to-transparent"></div>
    </div>


    {/* Layer 4: Playground HUD Toggle (Boutique Eye Switch) */}
    <div class="absolute bottom-40 left-1/2 -translate-x-1/2 md:translate-x-0 md:left-auto md:bottom-10 md:right-10 z-50 animate-in fade-in duration-1000 delay-[1500ms]">
      <button 
        id="hud-toggle"
        class="flex items-center gap-3 px-6 py-3 bg-zinc-900/60 backdrop-blur-xl border border-white/10 rounded-full text-[10px] font-black uppercase tracking-[0.15em] text-white/60 hover:text-white hover:bg-zinc-800/80 transition-all cursor-pointer shadow-2xl group min-w-[160px] justify-center"
      >
        <div class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse"></div>
        <span id="hud-toggle-text">Playground-Mode</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 group-hover:opacity-100 transition-opacity">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
      </button>
    </div>


  </section>





  {/* INTRO: Warum es im Sitz beginnt */}
  <section id="features" class="py-24 md:py-40 bg-surface/30">
    <div class="max-w-7xl mx-auto px-6 md:px-8 grid md:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <span class="inline-block px-4 py-1.5 rounded-full bg-brand/10 text-brand text-xs font-bold tracking-widest uppercase">
          Das Sitzprinzip
        </span>
        <h2 class="text-4xl md:text-6xl font-bold tracking-tight text-content leading-tight">
          {intro?.heading}
        </h2>
        <div class="prose prose-invert prose-lg text-content/70 leading-relaxed font-light">
          {intro?.content}
        </div>
        <p class="text-2xl font-bold text-brand italic">
          {intro?.subheading}
        </p>
      </div>
      <div class="relative flex items-center justify-center py-10">
         <div class="absolute inset-0 bg-brand/5 blur-[100px] rounded-full scale-75"></div>
         <img 
           src="/assets/8.png" 
           alt="Kinetic Harness Profile" 
           class="relative z-10 w-full h-auto object-contain animate-in fade-in zoom-in duration-1000 delay-300"
           style="filter: drop-shadow(0 20px 50px var(--theme-brand-glow));"
         />

      </div>

    </div>
  </section>

  {/* STORY SECTION 1 */}
  <section id="testimonials" class="py-24 bg-brand/5 border-y border-brand/10">

    <div class="max-w-4xl mx-auto px-6 text-center space-y-12">
      <span class="text-xs font-bold tracking-[0.3em] uppercase text-content/40">Kundenstory</span>
      <blockquote class="text-3xl md:text-5xl font-light italic text-content leading-snug">
        "{storyTired?.heading}"
      </blockquote>
      <p class="text-lg md:text-xl text-content/60 leading-relaxed max-w-2xl mx-auto font-light">
        {storyTired?.content}
      </p>
      <p class="text-xl font-bold text-brand italic">
        {storyTired?.subheading}
      </p>
    </div>
  </section>

  {/* TECH: CLS & CORE LOCK */}
  <section id="specs" class="modular-section relative py-24 md:py-40">

    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-20 space-y-6">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tight">
          {cls?.heading}
        </h2>
        <p class="text-xl text-content/60 font-light">
          {cls?.content}
        </p>
        <p class="text-2xl font-bold text-brand tracking-widest uppercase py-4">
          {cls?.subheading}
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 feature-grid">
         {cls?.items?.map(feature => (
           <div class="feature-block p-10 rounded-3xl bg-surface/50 border border-white/5 space-y-6 hover:border-brand/40 transition-all duration-300">
              <h3 class="text-xl font-bold text-brand">{feature.label}</h3>
              <p class="text-content/60 font-light leading-relaxed">{feature.value}</p>
           </div>
         ))}
      </div>

    </div>
  </section>

  {/* AGILITY CONTROL */}
  <section id="agility" class="modular-section relative py-24 bg-zinc-900 overflow-hidden text-white">

     <div class="max-w-7xl mx-auto px-6 md:px-8 grid md:grid-cols-2 gap-20 items-center">
        <div class="relative z-10 space-y-8">
            <h2 class="text-4xl md:text-6xl font-bold tracking-tight text-white" set:html={agility?.heading}></h2>
            <p class="text-xl text-white/70 font-light leading-relaxed" set:html={agility?.content}></p>
            <div class="p-6 bg-brand/10 border-l-4 border-brand rounded-r-2xl italic text-white/90 font-medium" set:html={agility?.subheading}></div>

        </div>

        <div class="relative flex items-center justify-center">
            <div class="absolute inset-0 bg-brand/10 blur-[120px] rounded-full"></div>
            <img 
              src="/assets/7.png" 
              alt="Agility Control Engineering" 
              class="relative z-10 w-full h-auto object-contain drop-shadow-2xl" 
            />
            <div class="absolute bottom-0 left-0 right-0 py-8 flex justify-between text-[10px] tracking-widest font-black uppercase text-brand/60 px-4">
               <span>Dämpfung Max</span>
               <span>Feedback Max</span>
            </div>
        </div>

     </div>
  </section>

  {/* SAFETY SECTION */}
  <section id="safety" class="modular-section relative py-24 md:py-40 bg-surface/30">

    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
         <div class="relative flex items-center justify-center py-20 group">
            <div class="absolute inset-0 bg-brand/5 blur-[120px] rounded-full scale-90 group-hover:bg-brand/10 transition-colors duration-1000"></div>
            
            {/* Guardian Radar Sweep */}
            <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden rounded-full">
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] opacity-20">
                <div class="w-full h-full border border-brand/20 rounded-full animate-ping-slow"></div>
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-full bg-gradient-to-b from-brand to-transparent origin-center animate-radar-sweep"></div>
              </div>
            </div>

            <img 
              src="/assets/6.png" 
              alt="Safety Technology" 
              class="relative z-10 w-full h-auto object-contain drop-shadow-[0_20px_50px_rgba(var(--theme-brand-rgb),0.2)] group-hover:scale-105 transition-transform duration-700" 
            />
         </div>


        <div class="space-y-8">
           <h2 class="text-4xl md:text-6xl font-bold tracking-tight">{safety?.heading}</h2>
           <p class="text-xl text-content/70 font-light leading-relaxed">{safety?.content}</p>
           <div class="space-y-6">
              {safety?.items?.map(item => (
                <div class="flex gap-4">
                  <div class="w-1.5 h-1.5 rounded-full bg-brand mt-2.5 shrink-0"></div>
                  <div>
                    <h3 class="font-bold text-lg">{item.label}</h3>
                    <p class="text-content/60 font-light">{item.value}</p>
                  </div>
                </div>
              ))}
           </div>
        </div>
      </div>
    </div>
  </section>

  {/* STORY SECTION 2: Fabric Flow */}
  <section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand/5 via-surface to-brand/5 animate-fabric-flow"></div>
    <div class="max-w-4xl mx-auto px-6 text-center space-y-12 relative z-10">
      <span class="text-xs font-bold tracking-[0.3em] uppercase text-content/40">Kundenstory</span>
      <blockquote class="text-3xl md:text-5xl font-light italic text-content leading-snug">
        "{storyCalm?.heading}"
      </blockquote>
      <p class="text-lg md:text-xl text-content/60 leading-relaxed max-w-2xl mx-auto font-light">
        {storyCalm?.content}
      </p>
      <p class="text-xl font-bold text-brand italic">
        {storyCalm?.subheading}
      </p>
    </div>
  </section>


  {/* MEDIA SECTION */}
  <section id="media" class="modular-section relative py-24 md:py-40">

     <div class="max-w-7xl mx-auto px-6 md:px-8 text-center space-y-16">
        <div class="space-y-4">
           <h2 class="text-4xl md:text-6xl font-bold tracking-tight">{media?.heading}</h2>
           <p class="text-xl text-content/60 font-light">{media?.subheading}</p>
        </div>
         <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 pt-10">
            {media && media.media_items && media.media_items.length > 0 ? (
              media.media_items.map((item: any) => (
                <div class="relative group cursor-pointer">
                   <div class="absolute inset-0 bg-brand/5 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                   <div class="aspect-[9/16] rounded-[2.5rem] overflow-hidden relative z-10 shadow-2xl transition-transform duration-500 group-hover:-translate-y-4">

                      {item.video_url && (

                        <div class="absolute inset-0 flex items-center justify-center z-20">
                          <div class="w-16 h-16 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center group-hover:scale-110 transition-transform">
                             <div class="w-0 h-0 border-l-[12px] border-l-white border-y-[8px] border-y-transparent ml-1"></div>
                          </div>
                        </div>
                      )}
                      <img 
                        src={item.thumbnail || "/assets/4.jpg"} 
                        alt={item.label || "Clip"} 
                        class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-all duration-700 group-hover:scale-110" 
                      />
                   </div>
                   {item.label && <p class="text-[10px] tracking-widest uppercase font-bold text-content/40 mt-4 group-hover:text-brand transition-colors">{item.label}</p>}
                </div>
              ))
            ) : (
              [1, 2, 3, 4].map(i => (
                <div class="relative group cursor-pointer">
                   <div class="absolute inset-0 bg-brand/5 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                   <div class="aspect-[9/16] rounded-[2.5rem] overflow-hidden relative z-10 shadow-2xl transition-transform duration-500 group-hover:-translate-y-4">
                      <div class="absolute inset-0 flex items-center justify-center z-20">
                         <div class="w-16 h-16 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center group-hover:scale-110 transition-transform">
                            <div class="w-0 h-0 border-l-[12px] border-l-white border-y-[8px] border-y-transparent ml-1"></div>
                         </div>
                      </div>
                      <img src={`/assets/4.jpg`} alt={`Clip ${i}`} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-all duration-700 group-hover:scale-110" />
                   </div>
                </div>
              ))
            )}
         </div>
         <p class="text-white/20 text-sm italic pt-10">{media?.content}</p>
     </div>
  </section>

  {/* TECHNICAL SPECS: The Boutique Technical Table */}
  <section id="specs-table" class="modular-section relative py-24 md:py-40 bg-zinc-950 text-white overflow-hidden">

    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="space-y-4 mb-20 text-center">
        <span class="text-brand text-xs font-bold tracking-[0.4em] uppercase">Tech Data Sheet</span>
        <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase italic">{specs?.heading}</h2>
      </div>

      <div class="space-y-2">
         {specs?.items?.map((item: any) => (
           <div class="group flex flex-col sm:flex-row sm:items-end justify-between py-6 border-b border-white/5 hover:border-brand/40 transition-colors relative overflow-hidden gap-2 sm:gap-4">
              <span class="text-[10px] md:text-xs font-black uppercase tracking-[0.25em] text-white/30 group-hover:text-white transition-colors shrink-0">
                {item.label}
              </span>
              
              {/* Technical Dotted Connector (Hidden on Mobile) */}
              <div class="hidden sm:block flex-grow border-b border-dotted border-white/10 mb-1.5 opacity-40 group-hover:opacity-100 group-hover:border-brand/30 transition-all"></div>
              
              <span class="text-xl md:text-2xl font-black tracking-tighter text-white/80 group-hover:text-brand transition-colors shrink-0 transition-transform duration-300 group-hover:scale-105 origin-left sm:origin-right">
                {item.value}
              </span>
           </div>
         ))}
      </div>
      
      <p class="text-white/20 text-xs italic text-center pt-12 font-light">
        {specs?.content || "Alle technischen Angaben vorbehaltlich Änderungen nach finaler Zertifizierung."}
      </p>
    </div>
  </section>


  {/* FIT SYSTEM */}
  <section id="sizing" class="modular-section relative py-24 md:py-40 bg-surface/30 overflow-hidden">

    {/* Blueprint Parallax Background Text */}
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[15vw] font-black text-content/5 uppercase leading-none select-none pointer-events-none tracking-tighter mix-blend-soft-light opacity-60">
      KINETIC
    </div>
">
    <div class="max-w-4xl mx-auto px-6 text-center space-y-8">
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight" set:html={fit?.heading}></h2>
      <p class="text-xl text-content/60 font-light" set:html={fit?.content}></p>
      <p class="text-2xl font-bold text-brand italic" set:html={fit?.subheading}></p>

      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-10">
         {fit?.items?.map(item => (
            <div class="p-5 md:p-8 bg-surface rounded-2xl border border-surface-border space-y-2">
               <span class="text-4xl md:text-5xl font-black text-brand inline-block">{item.value}</span>
               <span class="block text-[10px] md:text-xs uppercase tracking-[0.2em] text-content/40 font-bold">{item.label}</span>
            </div>
         ))}
      </div>

      <div class="pt-10">
         <a href="/kontakt" class="btn-outline">
            {fit?.button_text}
         </a>
      </div>

    </div>
  </section>

{/* FAQ */}

<section id="faq" class="modular-section relative py-24 md:py-40 border-t border-white/5">

  <div class="max-w-4xl mx-auto px-6 space-y-16">
    <h2 class="text-4xl font-bold text-center">{faq?.heading}</h2>
    <FAQAccordion items={faq?.items || []} client:visible />
  </div>
</section>


   {/* CONTACT CTA */}
   <section id="kontakt-cta" class="modular-section bg-brand text-white overflow-hidden py-24 md:py-40">
      <div class="max-w-5xl mx-auto px-6 text-center space-y-10">
         <h2 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic">Ready for Takeoff?</h2>
         <p class="text-xl md:text-2xl font-light opacity-80 max-w-2xl mx-auto">
           Werde Teil der Evolution. Behalte die volle Kontrolle und sichere dir jetzt deine KINETIC Konfiguration.
         </p>
         <div class="pt-10">
            <a href="/kontakt" class="inline-flex px-12 py-6 bg-white text-brand font-black text-xl rounded-full shadow-2xl hover:scale-105 active:scale-95 transition-all uppercase tracking-widest">
               JETZT KINETIC KONFIGURIEREN
            </a>
         </div>
      </div>
   </section>




  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Fade in sections
    gsap.utils.toArray('section').forEach((section: any) => {
      gsap.fromTo(section, 
        { opacity: 0, y: 50 },
        { 
          opacity: 1, 
          y: 0, 
          duration: 1, 
          scrollTrigger: {
            trigger: section,
            start: "top 80%",
            toggleActions: "play none none reverse"
          }
        }
      );
    });

    // Parallax for floating images
    gsap.utils.toArray('img').forEach((img: any) => {
      if (img.classList.contains('object-contain')) {
        gsap.to(img, {
          yPercent: -15,
          ease: "none",
          scrollTrigger: {
            trigger: img,
            scrub: true
          }
        });
      }
    });
    // HUD Toggle Logic
    const hudToggle = document.getElementById('hud-toggle');
    const heroHud = document.getElementById('hero-hud');
    const hudText = document.getElementById('hud-toggle-text');
    let isHidden = false;

    hudToggle?.addEventListener('click', () => {
      isHidden = !isHidden;
      if (isHidden) {
        gsap.to(heroHud, { opacity: 0, scale: 0.98, duration: 0.8, pointerEvents: 'none', ease: "power3.inOut" });
        if (hudText) hudText.innerText = "Show Text";
      } else {
        gsap.to(heroHud, { opacity: 1, scale: 1, duration: 0.6, pointerEvents: 'auto', ease: "power2.out" });
        if (hudText) hudText.innerText = "Playground-Mode";
      }
    });

    // Feature Grid Stagger (Modular Float-in)
    gsap.from(".feature-block", {
      scrollTrigger: {
        trigger: ".feature-grid",
        start: "top 95%",
      },
      x: (i) => i === 0 ? -100 : i === 2 ? 100 : 0,
      y: (i) => i === 1 ? 50 : 0,
      opacity: 0,
      duration: 1.2,
      stagger: 0.2,
      ease: "power3.out"
    });

  </script>

  <style is:global>

    @keyframes radar-sweep {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes ping-slow {
      0% { transform: scale(0.8); opacity: 0; }
      50% { opacity: 0.3; }
      100% { transform: scale(1.2); opacity: 0; }
    }
    @keyframes fabric-flow {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .animate-radar-sweep {
      animation: radar-sweep 8s linear infinite;
    }
    .animate-ping-slow {
      animation: ping-slow 4s ease-out infinite;
    }
    .animate-fabric-flow {
      background-size: 200% 200%;
      animation: fabric-flow 15s ease infinite;
    }
  </style>
  <style is:global>
    /* ... existing keyframes ... */
    
    /* Modular Narrative Engine (Root-Level Snap) */
    @media (min-width: 1024px) {
      html {
        scroll-snap-type: y mandatory;
        scroll-behavior: smooth;
      }
      .modular-section {
        scroll-snap-align: start;
        scroll-snap-stop: always;
        min-height: 100vh;
        display: flex;
        align-items: center;
        width: 100%;
      }
    }
  </style>

</MainLayout>





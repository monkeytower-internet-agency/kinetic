---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import Hero3D from "../components/Hero3D";
import FAQAccordion from "../components/FAQAccordion";



const allSections = await getCollection("sections");
const hero = allSections.find(s => s.data.slug === 'hero')?.data;
const intro = allSections.find(s => s.data.slug === 'intro')?.data;
const storyTired = allSections.find(s => s.data.slug === 'story-tired')?.data;
const cls = allSections.find(s => s.data.slug === 'cls')?.data;
const agility = allSections.find(s => s.data.slug === 'agility-control')?.data;
const safety = allSections.find(s => s.data.slug === 'safety')?.data;
const storyCalm = allSections.find(s => s.data.slug === 'story-calm')?.data;
const media = allSections.find(s => s.data.slug === 'media')?.data;
const specs = allSections.find(s => s.data.slug === 'specs')?.data;
const fit = allSections.find(s => s.data.slug === 'fit-system')?.data;

const faq = allSections.find(s => s.data.slug === 'faq')?.data;


// Brand Title
const pageTitle = "KINETIC | pure control - das neue Gurtzeug von Profly";
---

<MainLayout title={pageTitle}>
  {/* HERO SECTION */}
  <section id="hero" class="min-h-[100dvh] flex flex-col items-center justify-center text-center px-4 relative overflow-hidden bg-black">
    {/* Layer 0: Deep Background Base */}
    <div class="absolute inset-0 bg-gradient-to-b from-brand/20 via-black to-black opacity-80 pointer-events-none"></div>

    {/* Layer 1: Immersion Layer - Full width and height (No Boxes!) */}
    <div class="absolute inset-0 z-10 pointer-events-auto overflow-hidden">
      <Hero3D client:only="react" />
    </div>

    {/* Layer 2: Mobile Scroll Side-Grip (Invisible touch-path for scrolling on mobile - above 3D, below text) */}
    <div class="md:hidden absolute left-0 top-0 bottom-0 w-[15%] z-20 pointer-events-auto touch-pan-y"></div>
    <div class="md:hidden absolute right-0 top-0 bottom-0 w-[15%] z-20 pointer-events-auto touch-pan-y"></div>

    {/* Layer 3: Text & UI (Floating ABOVE the model) */}
    <div class="relative z-30 space-y-4 max-w-7xl mx-auto py-10">

      <div class="space-y-4">
        <p class="text-3xl md:text-5xl lg:text-7xl font-black tracking-[0.4em] text-brand uppercase animate-in fade-in slide-in-from-bottom-5 duration-1000 delay-300 drop-shadow-2xl">
          {hero?.subheading?.split('\n')[0] || "- pure control -"}
        </p>




        <p class="text-lg md:text-2xl text-white/40 max-w-2xl mx-auto font-light leading-relaxed animate-in fade-in duration-1000 delay-700">
          {hero?.subheading?.split('\n')[1] || "das neue Gurtzeug von Profly."}
        </p>
      </div>

      <div class="pt-8 flex flex-col md:flex-row gap-4 justify-center animate-in fade-in duration-1000 delay-1000 relative z-50">
        <a href="/kontakt" class="btn-primary min-w-[280px]">
          {hero?.button_text || "Beratung anfragen / Early Access"}
        </a>
      </div>

    </div>

    {/* Scroll Indicator - Mobile ONLY hint, acts as a scroll-safe bridge */}
    <div class="md:hidden absolute bottom-12 left-1/2 -translate-x-1/2 z-40 opacity-80 animate-pulse pointer-events-auto touch-pan-y flex flex-col items-center gap-4 cursor-row-resize w-[85vw]">
       <span class="text-[9px] tracking-[0.2em] uppercase font-black text-white select-none text-center">Swipe to Rotate / Scroll to continue</span>
       <div class="w-px h-8 bg-gradient-to-b from-white to-transparent"></div>
    </div>


  </section>




  {/* INTRO: Warum es im Sitz beginnt */}
  <section id="features" class="py-24 md:py-40 bg-surface/30">
    <div class="max-w-7xl mx-auto px-6 md:px-8 grid md:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <span class="inline-block px-4 py-1.5 rounded-full bg-brand/10 text-brand text-xs font-bold tracking-widest uppercase">
          Das Sitzprinzip
        </span>
        <h2 class="text-4xl md:text-6xl font-bold tracking-tight text-content leading-tight">
          {intro?.heading}
        </h2>
        <div class="prose prose-invert prose-lg text-content/70 leading-relaxed font-light">
          {intro?.content}
        </div>
        <p class="text-2xl font-bold text-brand italic">
          {intro?.subheading}
        </p>
      </div>
      <div class="relative flex items-center justify-center py-10">
         <div class="absolute inset-0 bg-brand/5 blur-[100px] rounded-full scale-75"></div>
         <img 
           src="/assets/8.png" 
           alt="Kinetic Harness Profile" 
           class="relative z-10 w-full h-auto object-contain animate-in fade-in zoom-in duration-1000 delay-300"
           style="filter: drop-shadow(0 20px 50px var(--theme-brand-glow));"
         />

      </div>

    </div>
  </section>

  {/* STORY SECTION 1 */}
  <section id="testimonials" class="py-24 bg-brand/5 border-y border-brand/10">

    <div class="max-w-4xl mx-auto px-6 text-center space-y-12">
      <span class="text-xs font-bold tracking-[0.3em] uppercase text-content/40">Kundenstory</span>
      <blockquote class="text-3xl md:text-5xl font-light italic text-content leading-snug">
        "{storyTired?.heading}"
      </blockquote>
      <p class="text-lg md:text-xl text-content/60 leading-relaxed max-w-2xl mx-auto font-light">
        {storyTired?.content}
      </p>
      <p class="text-xl font-bold text-brand italic">
        {storyTired?.subheading}
      </p>
    </div>
  </section>

  {/* TECH: CLS & CORE LOCK */}
  <section id="specs" class="py-24 md:py-40">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-20 space-y-6">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tight">
          {cls?.heading}
        </h2>
        <p class="text-xl text-content/60 font-light">
          {cls?.content}
        </p>
        <p class="text-2xl font-bold text-brand tracking-widest uppercase py-4">
          {cls?.subheading}
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
         {cls?.items?.map(feature => (
           <div class="p-10 rounded-3xl bg-surface/50 border border-white/5 space-y-6 hover:border-brand/40 transition-all duration-300">
              <h3 class="text-xl font-bold text-brand">{feature.label}</h3>
              <p class="text-content/60 font-light leading-relaxed">{feature.value}</p>
           </div>
         ))}
      </div>
    </div>
  </section>

  {/* AGILITY CONTROL */}
  <section id="agility" class="py-24 bg-zinc-900 overflow-hidden relative text-white">
     <div class="max-w-7xl mx-auto px-6 md:px-8 grid md:grid-cols-2 gap-20 items-center">
        <div class="relative z-10 space-y-8">
            <h2 class="text-4xl md:text-6xl font-bold tracking-tight text-white" set:html={agility?.heading}></h2>
            <p class="text-xl text-white/70 font-light leading-relaxed" set:html={agility?.content}></p>
            <div class="p-6 bg-brand/10 border-l-4 border-brand rounded-r-2xl italic text-white/90 font-medium" set:html={agility?.subheading}></div>

        </div>

        <div class="relative flex items-center justify-center">
            <div class="absolute inset-0 bg-brand/10 blur-[120px] rounded-full"></div>
            <img 
              src="/assets/7.png" 
              alt="Agility Control Engineering" 
              class="relative z-10 w-full h-auto object-contain drop-shadow-2xl" 
            />
            <div class="absolute bottom-0 left-0 right-0 py-8 flex justify-between text-[10px] tracking-widest font-black uppercase text-brand/60 px-4">
               <span>Dämpfung Max</span>
               <span>Feedback Max</span>
            </div>
        </div>

     </div>
  </section>

  {/* SAFETY SECTION */}
  <section id="safety" class="py-24 md:py-40 bg-surface/30">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="relative flex items-center justify-center py-20">
           <div class="absolute inset-0 bg-white/5 blur-[100px] rounded-full scale-90"></div>
           <img 
             src="/assets/6.png" 
             alt="Safety Technology" 
             class="relative z-10 w-full h-auto object-contain drop-shadow-[0_10px_30px_rgba(255,255,255,0.1)]" 
           />
        </div>

        <div class="space-y-8">
           <h2 class="text-4xl md:text-6xl font-bold tracking-tight">{safety?.heading}</h2>
           <p class="text-xl text-content/70 font-light leading-relaxed">{safety?.content}</p>
           <div class="space-y-6">
              {safety?.items?.map(item => (
                <div class="flex gap-4">
                  <div class="w-1.5 h-1.5 rounded-full bg-brand mt-2.5 shrink-0"></div>
                  <div>
                    <h3 class="font-bold text-lg">{item.label}</h3>
                    <p class="text-content/60 font-light">{item.value}</p>
                  </div>
                </div>
              ))}
           </div>
        </div>
      </div>
    </div>
  </section>

  {/* STORY SECTION 2 */}
  <section class="py-24 bg-brand/5 border-y border-brand/10">
    <div class="max-w-4xl mx-auto px-6 text-center space-y-12">
      <span class="text-xs font-bold tracking-[0.3em] uppercase text-content/40">Kundenstory</span>
      <blockquote class="text-3xl md:text-5xl font-light italic text-content leading-snug">
        "{storyCalm?.heading}"
      </blockquote>
      <p class="text-lg md:text-xl text-content/60 leading-relaxed max-w-2xl mx-auto font-light">
        {storyCalm?.content}
      </p>
      <p class="text-xl font-bold text-brand italic">
        {storyCalm?.subheading}
      </p>
    </div>
  </section>

  {/* MEDIA SECTION */}
  <section id="media" class="py-24 md:py-40">
     <div class="max-w-7xl mx-auto px-6 md:px-8 text-center space-y-16">
        <div class="space-y-4">
           <h2 class="text-4xl md:text-6xl font-bold tracking-tight">{media?.heading}</h2>
           <p class="text-xl text-content/60 font-light">{media?.subheading}</p>
        </div>
         <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 pt-10">
            {media && media.media_items && media.media_items.length > 0 ? (
              media.media_items.map((item: any) => (
                <div class="relative group cursor-pointer">
                   <div class="absolute inset-0 bg-brand/5 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                   <div class="aspect-[9/16] rounded-[2.5rem] overflow-hidden relative z-10 shadow-2xl transition-transform duration-500 group-hover:-translate-y-4">

                      {item.video_url && (

                        <div class="absolute inset-0 flex items-center justify-center z-20">
                          <div class="w-16 h-16 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center group-hover:scale-110 transition-transform">
                             <div class="w-0 h-0 border-l-[12px] border-l-white border-y-[8px] border-y-transparent ml-1"></div>
                          </div>
                        </div>
                      )}
                      <img 
                        src={item.thumbnail || "/assets/4.jpg"} 
                        alt={item.label || "Clip"} 
                        class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-all duration-700 group-hover:scale-110" 
                      />
                   </div>
                   {item.label && <p class="text-[10px] tracking-widest uppercase font-bold text-content/40 mt-4 group-hover:text-brand transition-colors">{item.label}</p>}
                </div>
              ))
            ) : (
              [1, 2, 3, 4].map(i => (
                <div class="relative group cursor-pointer">
                   <div class="absolute inset-0 bg-brand/5 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                   <div class="aspect-[9/16] rounded-[2.5rem] overflow-hidden relative z-10 shadow-2xl transition-transform duration-500 group-hover:-translate-y-4">
                      <div class="absolute inset-0 flex items-center justify-center z-20">
                         <div class="w-16 h-16 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center group-hover:scale-110 transition-transform">
                            <div class="w-0 h-0 border-l-[12px] border-l-white border-y-[8px] border-y-transparent ml-1"></div>
                         </div>
                      </div>
                      <img src={`/assets/4.jpg`} alt={`Clip ${i}`} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-all duration-700 group-hover:scale-110" />
                   </div>
                </div>
              ))
            )}
         </div>
         <p class="text-white/20 text-sm italic pt-10">{media?.content}</p>
     </div>
  </section>


  {/* TECHNICAL SPECS */}
  <section id="specs-table" class="py-24 md:py-40 bg-zinc-900 text-white">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-4xl font-bold mb-12 text-center text-white">{specs?.heading}</h2>
      <div class="divide-y divide-white/10 border-y border-white/10">
         {specs?.items?.map(item => (
           <div class="grid grid-cols-2 py-6">
              <span class="text-white/40 font-bold uppercase tracking-widest text-xs">{item.label}</span>
              <span class="text-lg font-light text-white">{item.value}</span>
           </div>
         ))}
      </div>
    </div>
  </section>


  {/* FIT SYSTEM */}
  <section id="sizing" class="py-24 md:py-40 bg-surface/30">
    <div class="max-w-4xl mx-auto px-6 text-center space-y-8">
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight" set:html={fit?.heading}></h2>
      <p class="text-xl text-content/60 font-light" set:html={fit?.content}></p>
      <p class="text-2xl font-bold text-brand italic" set:html={fit?.subheading}></p>

      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-10">
         {fit?.items?.map(item => (
            <div class="p-5 md:p-8 bg-surface rounded-2xl border border-surface-border space-y-2">
               <span class="text-4xl md:text-5xl font-black text-brand inline-block">{item.value}</span>
               <span class="block text-[10px] md:text-xs uppercase tracking-[0.2em] text-content/40 font-bold">{item.label}</span>
            </div>
         ))}
      </div>

      <div class="pt-10">
         <a href="/kontakt" class="btn-outline">
            {fit?.button_text}
         </a>
      </div>

    </div>
  </section>

{/* FAQ */}

<section id="faq" class="py-24 md:py-40 border-t border-white/5">
  <div class="max-w-4xl mx-auto px-6 space-y-16">
    <h2 class="text-4xl font-bold text-center">{faq?.heading}</h2>
    <FAQAccordion items={faq?.items || []} client:visible />
  </div>
</section>


   {/* CONTACT CTA */}
   <section id="kontakt-cta" class="py-24 md:py-40 bg-brand text-white">
      <div class="max-w-5xl mx-auto px-6 text-center space-y-10">
         <h2 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic">Ready for Takeoff?</h2>
         <p class="text-xl md:text-2xl font-light opacity-80 max-w-2xl mx-auto">
           Werde Teil der Evolution. Behalte die volle Kontrolle und sichere dir jetzt deine KINETIC Konfiguration.
         </p>
         <div class="pt-10">
            <a href="/kontakt" class="inline-flex px-12 py-6 bg-white text-brand font-black text-xl rounded-full shadow-2xl hover:scale-105 active:scale-95 transition-all uppercase tracking-widest">
               JETZT KINETIC KONFIGURIEREN
            </a>
         </div>
      </div>
   </section>


  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Fade in sections
    gsap.utils.toArray('section').forEach((section: any) => {
      gsap.fromTo(section, 
        { opacity: 0, y: 50 },
        { 
          opacity: 1, 
          y: 0, 
          duration: 1, 
          scrollTrigger: {
            trigger: section,
            start: "top 80%",
            toggleActions: "play none none reverse"
          }
        }
      );
    });

    // Parallax for floating images
    gsap.utils.toArray('img').forEach((img: any) => {
      if (img.classList.contains('object-contain')) {
        gsap.to(img, {
          yPercent: -15,
          ease: "none",
          scrollTrigger: {
            trigger: img,
            scrub: true
          }
        });
      }
    });
  </script>
</MainLayout>


---
import MainLayout from "../layouts/MainLayout.astro";
import QuizWizard from "../components/QuizWizard";

const turnstileSiteKey =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ||
  process.env.PUBLIC_TURNSTILE_SITE_KEY ||
  "";

const pageTitle = "Projekt-Check | ParaNomad";
---

<MainLayout title={pageTitle}>
  <main class="py-24 px-4 bg-surface min-h-[80vh]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2
          class="text-[10px] font-bold uppercase tracking-[0.4em] text-brand mb-4"
        >
          Projekt-Check
        </h2>
        <h2
          class="text-4xl md:text-6xl font-extralight text-content tracking-tighter mb-4 antialiased leading-tight"
        >
          Dein Weg zum <span class="font-bold text-brand">perfekten</span> Ausbau.
        </h2>
        <p
          class="text-content/70 text-lg font-light tracking-wide max-w-xl mx-auto"
        >
          Beantworte ein paar Fragen und wir finden gemeinsam heraus, welches
          Setup am besten zu deinen Reiseplänen passt.
        </p>
      </div>

      <div class="max-w-4xl mx-auto mt-12">
        <QuizWizard turnstileSiteKey={turnstileSiteKey} client:load />
      </div>
    </div>
  </main>
</MainLayout>

---
// src/layouts/MainLayout.astro
import Header from "../components/Header";
import CursorGlow from "../components/CursorGlow";

import Footer from "../components/Footer";
import Announcement from "../components/Announcement";
import { ClientRouter } from "astro:transitions";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getEntry } from "astro:content";

import "../styles/global.css";

interface Props {
  title?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Fetch Global Settings
const settings = await getEntry("settings", "index");

const { title = t("footer.tagline") } = Astro.props;
---

<!doctype html>
<html lang={lang} class="dark" data-brand="verkehrsrot">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        const savedMode = localStorage.getItem("theme-mode") || "system";
        const savedAccent = localStorage.getItem("theme-accent") || "verkehrsrot";
        const isContrast = localStorage.getItem("theme-contrast") === "true";
        const savedTextSize = localStorage.getItem("theme-text-size") || "2";

        const applyMode = (mode) => {
          if (mode === "dark" || (mode === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.classList.remove("dark");
          }
        };

        applyMode(savedMode);
        document.documentElement.setAttribute("data-brand", savedAccent);
        if (isContrast) document.documentElement.classList.add("high-contrast");
        
        const sizes = ["small", "base", "medium", "large", "xl"];
        document.documentElement.classList.add(`text-size-${sizes[parseInt(savedTextSize)] || "base"}`);

        // Handle Astro View Transitions - Persist on navigation
        document.addEventListener('astro:after-swap', () => {
          applyMode(localStorage.getItem("theme-mode") || "system");
          document.documentElement.setAttribute("data-brand", localStorage.getItem("theme-accent") || "verkehrsrot");
          if (localStorage.getItem("theme-contrast") === "true") document.documentElement.classList.add("high-contrast");
        });
      })();
    </script>
    <ClientRouter fallback="swap" />

    <style is:global>
      /* Smooth transitions for View Transitions */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 0.3s;
        animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      }


      @keyframes pulse-subtle {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.8;
        }
      }
      .animate-pulse-subtle {
        animation: pulse-subtle 3s ease-in-out infinite;
      }
    </style>
  </head>

  <body
    class="bg-body text-content antialiased overflow-x-hidden transition-colors duration-500"
  >
    <Header lang={lang} announcement={settings?.data?.announcement} client:load transition:persist />

    <CursorGlow client:load />



    <div class="relative" transition:animate="fade">
      <main>
        <slot />
      </main>
    </div>

    <Footer lang={lang} client:load transition:persist />
  </body>

</html>

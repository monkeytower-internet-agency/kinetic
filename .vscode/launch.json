{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "paraNOMAD: Start Branch (main)",
      "request": "launch",
      "type": "node-terminal",
      "command": "npm run dev -- --port 4321 --host",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "paraNOMAD: Debug main in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "https://mac.dev.paranomad.de",
